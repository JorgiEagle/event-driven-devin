# GitHub personal access token (required for issue listing and webhook auto-registration)
# Needs: repo scope (or minimum: issues:read + admin:repo_hook)
EDD_GITHUB_TOKEN=

# GitHub webhook secret (optional, for verifying webhook signatures)
EDD_GITHUB_WEBHOOK_SECRET=

# Devin API token (required for automated session creation)
EDD_DEVIN_API_TOKEN=

# ngrok auth token (optional, required only for tunnel)
# Sign up free at https://ngrok.com/signup
NGROK_AUTHTOKEN=
